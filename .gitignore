# Only custom code is versioned. WordPress core, uploads, third-party
# plugins and environment config stay out of git.

/*
!/.gitignore
!/README.md
!/composer.json
!/composer.lock
!/wp-config.example.php
!/.github/
!/.github/**
!/scripts/
!/scripts/**
!/wp-content/
/wp-content/*
!/wp-content/plugins/
/wp-content/plugins/*
!/wp-content/plugins/komunikazioa/
!/wp-content/plugins/komunikazioa/**
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/kostan/
!/wp-content/themes/kostan/**

# Local environment (never commit secrets)
wp-config.php
.env
.env.*
!.env.deploy.example

# Theme build artifacts and dependencies
wp-content/themes/kostan/node_modules/
wp-content/themes/kostan/dist/

# Composer vendor at project root (if used)
/vendor/

# OS / editor
.DS_Store
*.code-workspace
Thumbs.db

# Local backups and stray files
/db_backup/
/*.png
/*.sql

# Logs
*.log
npm-debug.log*

# Dependencies (global)
node_modules/
