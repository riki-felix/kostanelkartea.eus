# Copy to .env.deploy and fill with values from MyKinsta > Sites > LIVE > Info > SFTP/SSH.
# .env.deploy is gitignored. Use this for the PRE environment (Kinsta LIVE before final domain).

KINSTA_SSH_HOST=12.34.56.78
KINSTA_SSH_PORT=12345
KINSTA_SSH_USER=your-site-user
KINSTA_SSH_PASSWORD=your-ssh-password

# Absolute path shown in MyKinsta > Info > Environment details > Path
KINSTA_REMOTE_PATH=/www/your-site/public

# Optional: use an SSH key instead of password (recommended for CI).
# KINSTA_SSH_KEY=$HOME/.ssh/kinsta_deploy

# Optional overrides:
# DRY_RUN=true
# BUILD_THEME=true
# PURGE_CACHE=true
